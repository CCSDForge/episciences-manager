{
  "categories": [
    { "title": "✨ Features", "labels": ["feat", "feature", "enhancement"] },
    { "title": "🐛 Bug Fixes", "labels": ["bug", "fix", "bugfix", "hotfix"] },
    { "title": "🔒 Security", "labels": ["security", "vulnerability"] },
    { "title": "⚡ Performance", "labels": ["perf", "performance"] },
    { "title": "🧰 Maintenance", "labels": ["chore", "dependencies", "deps", "refactor", "build"] },
    { "title": "📝 Documentation", "labels": ["documentation", "docs"] },
    { "title": "🧪 Tests", "labels": ["test", "tests", "testing"] },
    { "title": "🎨 Style", "labels": ["style", "lint"] },
    { "title": "⚙️ CI/CD", "labels": ["ci", "pipeline", "github-actions"] }
  ],
  "label_extractor": [
    {
      "pattern": "^(feat|feature|enhancement)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(fix|bugfix|hotfix)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(security)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(perf|performance)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(chore|refactor|build)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(docs|documentation)(\\(.*\\))?:",
      "target": "docs"
    },
    {
      "pattern": "^(test|tests|testing)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(style|lint)(\\(.*\\))?:",
      "target": "$1"
    },
    {
      "pattern": "^(ci)(\\(.*\\))?:",
      "target": "$1"
    }
  ],
  "ignore_labels": ["skip-changelog"],
  "sort": { "order": "DESC", "on_property": "authoredDate" },
  "pr_template": "- ${{TITLE}} (#${{NUMBER}}) by @${{AUTHOR}}",
  "commit_template": "- ${{TITLE}} (${{SHA_SHORT}}) by @${{AUTHOR}}",
  "empty_template": "_No changes._",
  "max_commits_per_category": 200
}