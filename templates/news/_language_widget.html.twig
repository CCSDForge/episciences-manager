{#
Language Widget Component
Parameters:
- acceptedLanguages: array of language codes ['en', 'fr', ...]
- defaultLanguage: default language code
- mode: 'create' or 'edit'
- currentNews: (optional) the news entity being edited (for edit mode)
#}

<div class="language-widget border rounded" data-widget-mode="{{ mode }}">
    <button class="btn btn-link w-100 d-flex justify-content-between align-items-center px-3 py-2
  text-decoration-none"
            type="button" data-bs-toggle="collapse" data-bs-target="#languagesPanel" aria-expanded="true">
        <span class="fw-semibold text-dark">{{ 'news.languages'|trans }}</span>
        <i class="fas fa-chevron-up collapse-icon"></i>
    </button>

    <div class="collapse show" id="languagesPanel">
        <!-- Language selector dropdown -->
        <div class="px-3 py-2 border-top">
            <label class="form-label small text-muted mb-1">
                {{ 'news.editLanguage'|trans }}
            </label>
            <select class="form-select form-select-sm" id="content-language-select">
                {# En mode create: langue par défaut uniquement #}
                {# En mode edit: langues avec contenu #}
                {% if mode == 'create' %}
                    <option value="{{ defaultLanguage }}" selected>
                        {{ defaultLanguage|language_name(defaultLanguage)|default(defaultLanguage|upper)|capitalize }}
                    </option>
                {% else %}
                    {% for lang in acceptedLanguages %}
                        {% set hasContent = currentNews is defined and (currentNews.title[lang] is
                            defined or currentNews.content[lang] is defined) %}
                        {% if hasContent %}
                            <option value="{{ lang }}" {{ defaultLanguage == lang ? 'selected' : '' }}>
                                {{ lang|language_name(lang)|default(lang|upper)|capitalize }}
                            </option>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </select>
        </div>

        <!-- Translations list -->
        <div class="px-3 py-2 border-top">
            <label class="form-label small text-muted mb-1">{{ 'news.translations'|trans }}</label>
            <div id="translations-list" class="translations-list">
                {% for lang in acceptedLanguages %}
                    {% set hasContent = false %}
                    {% set titleText = '' %}
                    {% set contentText = '' %}

                    {% if mode == 'edit' and currentNews is defined %}
                        {# Mode edit : données existantes #}
                        {% set titleText = currentNews.title[lang]|default('') %}
                        {% set contentText = currentNews.content[lang]|default('')|striptags %}
                        {% set hasContent = titleText is not empty or contentText is not empty %}
                    {% elseif mode == 'create' and lang == defaultLanguage %}
                        {# Mode create : tout est vide au départ #}
                        {# JavaScript mettra à jour dynamiquement #}
                        {% set hasContent = false %}
                    {% endif %}

                    <div class="translation-row d-flex align-items-center gap-2 mb-1"
                         data-lang="{{ lang }}"
                         data-has-content="{{ hasContent ? 'true' : 'false' }}">

                        <button type="button"
                                class="btn btn-link btn-sm p-0 translation-action-btn"
                                data-lang="{{ lang }}"
                                title="{{ hasContent ? 'news.editTranslation'|trans :
                                'news.addTranslation'|trans }}">
                            <i class="fas {{ hasContent ? 'fa-pen text-primary' : 'fa-plus text-muted'
                            }}"></i>
                        </button>

                        <span class="translation-lang text-muted small" style="width: 30px;">
                              {{ lang|upper }}
                          </span>

                        {% if hasContent %}
                        {# Titre #}
                        <span class="translation-title-preview text-truncate small"
                              style="max-width: 120px;"
                              title="{{ titleText }}">
                          {% if titleText %}
                              {{ titleText|slice(0, 20) }}{% if titleText|length > 20 %}...{% endif %}
                          {% else %}
                              <span class="text-muted fst-italic">-</span>
                          {% endif %}
                      </span>

                        <span class="text-muted">|</span>

                        <span class="translation-title-preview text-truncate text-muted flex-grow-1 small"  title="{{ contentText }}">
                              {% if contentText %}
                                  {{ contentText|slice(0, 30) }}{% if contentText|length > 30 %}...{% endif %}
                              {% else %}
                                  <span class="text-muted fst-italic">{{ 'news.noContent'|trans }}</span>
                              {% endif %}
                          </span>
                        {% else %}
                            <span class="text-muted fst-italic small flex-grow-1">
                          {{ 'news.noContent'|trans }}
                      </span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<!-- Hidden inputs for all translations -->
<div id="translations-data">
    {% for lang in acceptedLanguages %}
        <input type="hidden" name="translations[{{ lang }}][title]" id="translation-title-{{ lang }}"
               value="{% if currentNews is defined %}{{ currentNews.title[lang]|default('') }}{% endif
               %}">
        <input type="hidden" name="translations[{{ lang }}][content]" id="translation-content-{{ lang
        }}"
               value="{% if currentNews is defined %}{{ currentNews.content[lang]|default('') }}{% endif
               %}">
        <input type="hidden" name="translations[{{ lang }}][link]" id="translation-link-{{ lang }}"
               value="{% if currentNews is defined %}{{ currentNews.link[lang]|default('') }}{% endif
               %}">
    {% endfor %}
</div>

<script>
  window.newsLanguageConfig = {
    acceptedLanguages: {{ acceptedLanguages|json_encode|raw }},
    defaultLanguage: '{{ defaultLanguage }}',
    langNames: {
      {% for lang in acceptedLanguages %}
        '{{ lang }}': '{{ lang|language_name(lang)|default(lang|upper)|capitalize }}'{{ not loop.last ? ',' : '' }}
      {% endfor %}
    },
    mode: '{{ mode }}'
  };
</script>
