{% extends 'base.html.twig' %}

{% block title %}Accueil - Episciences Manager{% endblock %}

{% block body %}
    <div class="container  review-container">
        {% if app.user and app.user.userIdentifier != '__NO_USER__' %}
            {% include 'partials/navbar.html.twig' %}
        {% endif %}
        <div class="text-center my-5">
            <h1>{{ 'home.welcome_title' |trans }}</h1>
            <h2 class="review-title text-center">{{ 'reviews.list_title'|trans }}</h2>
            <div>

                {% include 'components/flash_messages.html.twig' with {types: ['logout_success', 'success']} %}

                {% if reviews is defined and reviews.items is not empty %}
                    {# Affichage du total #}
                    <div class="text-center mb-3">
                <span class="badge bg-primary">
                    {{ reviews.totalItemCount }} {{ 'home.total_journals'|trans }}
                </span>
                    </div>

                    {# Liste des revues #}
                    <div class="list-group">
                        {% for review in reviews %}
                            <a href="{{ review.url }}" class="list-group-item clearfix" target="_blank">
                                <img src="{{ asset('build/images/logo-' ~ review.code ~ '.svg') }}"
                                     onerror="this.onerror=null; this.src='{{ asset('build/images/logo-' ~ review.code ~ '-preprod.svg') }}';"
                                     alt="Logo {{ review.code }}" class="review-logo">
                                <span class="review-name">{{ review.name }}</span>
                                <i class="fa fa-external-link review-link"></i>
                            </a>
                        {% endfor %}
                    </div>

                    {# Pagination #}
                    <div class="d-flex justify-content-center mt-4">
                        {{ knp_pagination_render(reviews, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
                    </div>

                {% else %}
                    <div class="alert alert-info text-center">
                        <i class="fa fa-info-circle"></i>
                        {{ 'home.no_journals_available'|trans }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
 {% block stylesheets %}
     {{ parent() }}
     {{ encore_entry_link_tags('index') }}
     {{ encore_entry_link_tags('navbar') }}
 {% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('home') }}
{% endblock %}
