{% extends 'base.html.twig' %}

{% block body %}

<!-- Main Layout with columns -->
<div class="row gx-4">
    <!-- Left column for future content -->
    <div class="col-1 d-none d-xl-block">
        <!-- Future content here -->
    </div>

    <!-- Main column -->
    <div class="col-12 col-xl-10">
        <!-- Hidden checkbox for mobile menu toggle (CSS-only) -->
        <input type="checkbox" id="mobile-menu-toggle" class="mobile-menu-checkbox" aria-hidden="true">

        <!-- Mobile: Logo + Title stacked -->
        <div class="mobile-header d-md-none mt-3 px-3 text-center">
            <div class="journal-logo mb-3">
                <img src="{{ asset('build/images/logo-' ~ review.code ~ '.svg') }}"
                     onerror="this.onerror=null; this.src='{{ asset('build/images/logo-' ~ review.code ~ '-preprod.svg') }}';"
                     alt="{{ review.name }} Logo" class="img-fluid logo" style="max-width: 150px;">
            </div>
            <div class="journal-title">
                <h1 class="h4 mb-0 text-primary fw-bold">{{ review.name }}</h1>
            </div>
            <!-- Mobile Menu Button (label for checkbox) -->
            {% if pages is defined and pages.main is not empty %}
                <div class="mt-3">
                    <label for="mobile-menu-toggle" class="btn btn-outline-primary w-100 mobile-menu-btn">
                        <i class="fas fa-bars me-2"></i>
                        {{ 'journalPages.menu'|trans|default('Menu') }}
                    </label>
                </div>
            {% endif %}
        </div>

        <!-- Main Layout -->
        <div class="mt-4">
            <!-- Row 1: Logo + Title + Back (Desktop only) - aligned with grid below -->
            <div class="journal-header d-none d-md-grid align-items-center mb-4">
                <!-- Logo (aligned with sidebar) -->
                <div class="text-center">
                    <img src="{{ asset('build/images/logo-' ~ review.code ~ '.svg') }}"
                         onerror="this.onerror=null; this.src='{{ asset('build/images/logo-' ~ review.code ~ '-preprod.svg') }}';"
                         alt="{{ review.name }} Logo" class="img-fluid logo">
                </div>
                <!-- Title (aligned with content) -->
                <div class="ps-3">
                    <h1 class="h3 mb-0 text-primary fw-bold">{{ review.name }}</h1>
                </div>
                <!-- Back button and Resources (aligned with widget) -->
                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_resources_manager', {'code': code}) }}" class="btn btn-outline-success btn-sm"
                       target="_blank" rel="noopener noreferrer">
                        <i class="fas fa-folder-open me-1"></i>
                        {{ 'journalDashboard.resources'|trans }}
                    </a>
                    <a href="{{ path('app_journal_dashboard', {'code': code}) }}"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>
                        {{ 'journalPages.back'|trans }}
                    </a>
                </div>
            </div>

            <!-- Flash Messages (bottom right toast) -->
            {% include 'components/flash_messages.html.twig' %}

            <!-- Row 2: Sidebar + Content + Language Widget -->
            <div class="journal-layout">
                <!-- Mobile backdrop (CSS-only) -->
                <label for="mobile-menu-toggle" class="mobile-menu-backdrop d-md-none"></label>

                <!-- Sidebar (CSS-only responsive) -->
                <div class="journal-layout__sidebar" id="sidebarMenu">
                    {% if pages is defined and pages.main is not empty %}
                        <!-- Mobile header -->
                        <div class="d-flex justify-content-between align-items-center p-3 border-bottom bg-light d-md-none">
                            <h5 class="mb-0">{{ 'journalPages.menu'|trans|default('Menu') }}</h5>
                            <label for="mobile-menu-toggle" class="btn-close" aria-label="Close"></label>
                        </div>
                        <!-- Sidebar content -->
                        <nav class="nav flex-column bg-light rounded p-3 sidebar-menu">
                            <a class="nav-link home-nav-link py-2 {% if currentPage is not defined or currentPage == '' %}active{% endif %}"
                               href="{{ path('app_journal_pages', {'code': code}) }}">
                                <i class="fas fa-home me-2"></i>
                                {{ 'journalPages.home' | trans }}
                            </a>

                            {% for page in pages.main %}
                                {% set isContainer = page.type is defined and page.type == 'container' %}
                                {% set pageKey = isContainer ? (page.title['en'] ?? page.title) : (page.pageCode ?? page.title['en']) %}
                                {% set hasSubPages = pages.sub[pageKey] is defined and pages.sub[pageKey] is not empty %}
                                {% set collapseId = 'collapse-' ~ loop.index %}
                                {% set isCurrentPage = not isContainer and currentPage is defined and currentPage == (page.pageCode|page_slug) %}

                                {% if hasSubPages %}
                                    {# Check if any subpage is active to expand this collapse #}
                                    {% set hasActiveChild = false %}
                                    {% for subPage in pages.sub[pageKey] %}
                                        {% if currentPage is defined and currentPage == (subPage.pageCode|default('')|page_slug) %}
                                            {% set hasActiveChild = true %}
                                        {% endif %}
                                    {% endfor %}

                                    <a class="nav-link py-2 d-flex justify-content-between align-items-center"
                                       id="nav-{% if isContainer %}container-{{ pageKey|lower|replace({' ': '-', '.': '-', '&': 'and'}) }}{% else %}page-{{ page.pageCode }}{% endif %}"
                                       data-bs-toggle="collapse"
                                       href="#{{ collapseId }}"
                                       role="button"
                                       aria-expanded="{{ hasActiveChild ? 'true' : 'false' }}"
                                       aria-controls="{{ collapseId }}">
                                            <span>
                                                {% if isContainer %}
                                                    {{ page.title[app.request.locale] ?? page.title[defaultLanguage] ?? page.title }}
                                                {% else %}
                                                    {{ page.title[app.request.locale] ?? page.title[defaultLanguage] ?? page.pageCode }}
                                                {% endif %}
                                            </span>
                                        <i class="fas fa-chevron-down fa-xs"></i>
                                    </a>
                                    <div class="collapse {% if hasActiveChild %}show{% endif %}" id="{{ collapseId }}">
                                        <nav class="nav flex-column ms-3">
                                            {% for subPage in pages.sub[pageKey] %}
                                                {% set isSubContainer = subPage.type is defined and subPage.type == 'container' %}
                                                {% set subPageKey = isSubContainer ? (subPage.title['en'] ?? subPage.title) : subPage.pageCode %}
                                                {% set hasNestedSubPages = isSubContainer and pages.sub[subPageKey] is defined and pages.sub[subPageKey] is not empty %}
                                                {% set subCollapseId = 'collapse-' ~ loop.parent.loop.index ~ '-' ~ loop.index %}
                                                {% set isSubCurrentPage = not isSubContainer and currentPage is defined and currentPage == (subPage.pageCode|page_slug) %}

                                                {% if hasNestedSubPages %}
                                                    {# Check if any nested page is active #}
                                                    {% set hasActiveNested = false %}
                                                    {% for nestedPage in pages.sub[subPageKey] %}
                                                        {% if currentPage is defined and currentPage == (nestedPage.pageCode|page_slug) %}
                                                            {% set hasActiveNested = true %}
                                                        {% endif %}
                                                    {% endfor %}

                                                    <a class="nav-link py-1 d-flex justify-content-between align-items-center"
                                                       id="nav-{% if isSubContainer %}container-{{ subPageKey|lower|replace({' ': '-', '.': '-', '&': 'and'}) }}{% else %}page-{{ subPage.pageCode }}{% endif %}"
                                                       data-bs-toggle="collapse"
                                                       href="#{{ subCollapseId }}"
                                                       role="button"
                                                       aria-expanded="{{ hasActiveNested ? 'true' : 'false' }}"
                                                       aria-controls="{{ subCollapseId }}">
                                                            <span>
                                                                {% if isSubContainer %}
                                                                    {{ subPage.title[app.request.locale] ?? subPage.title[defaultLanguage] ?? subPage.title }}
                                                                {% else %}
                                                                    {{ subPage.title[app.request.locale] ?? subPage.title[defaultLanguage] ?? subPage.pageCode }}
                                                                {% endif %}
                                                            </span>
                                                        <i class="fas fa-chevron-down fa-xs"></i>
                                                    </a>
                                                    <div class="collapse {% if hasActiveNested %}show{% endif %}"
                                                         id="{{ subCollapseId }}">
                                                        <nav class="nav flex-column ms-3">
                                                            {% for nestedPage in pages.sub[subPageKey] %}
                                                                {% set isNestedCurrentPage = currentPage is defined and currentPage == (nestedPage.pageCode|page_slug) %}
                                                                <a class="nav-link page-nav-link py-1 {% if isNestedCurrentPage %}active{% endif %}"
                                                                   id="nav-page-{{ nestedPage.pageCode }}"
                                                                   href="{{ path('app_journal_page_view', {'code': code, 'pageCode': nestedPage.pageCode|page_slug}) }}">
                                                                    {{ nestedPage.title[app.request.locale] ?? nestedPage.title[defaultLanguage] ?? nestedPage.pageCode }}
                                                                </a>
                                                            {% endfor %}
                                                        </nav>
                                                    </div>
                                                {% else %}
                                                    <a class="nav-link page-nav-link py-1 {% if isSubCurrentPage %}active{% endif %}"
                                                       id="nav-page-{{ subPage.pageCode }}"
                                                       href="{{ path('app_journal_page_view', {'code': code, 'pageCode': subPage.pageCode|page_slug}) }}">
                                                        {{ subPage.title[app.request.locale] ?? subPage.title[defaultLanguage] ?? subPage.pageCode }}
                                                    </a>
                                                {% endif %}
                                            {% endfor %}
                                        </nav>
                                    </div>
                                {% else %}
                                    {% if isContainer %}
                                        <span class="nav-link py-2 text-muted">
                                                {{ page.title[app.request.locale] ?? page.title[defaultLanguage] ?? page.title }}
                                            </span>
                                    {% else %}
                                        <a class="nav-link page-nav-link py-2 {% if isCurrentPage %}active{% endif %}"
                                           id="nav-page-{{ page.pageCode }}"
                                           href="{{ path('app_journal_page_view', {'code': code, 'pageCode': page.pageCode|page_slug}) }}">
                                            {{ page.title[app.request.locale] ?? page.title[defaultLanguage] ?? page.pageCode }}
                                        </a>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </nav>
                    {% endif %}
                </div>

                <!-- Content -->
                <div class="journal-layout__content">
                    {% if currentPageData is defined and currentPageData is not null %}
                        <!-- Breadcrumb Navigation -->
                        <nav aria-label="breadcrumb" class="bg-light rounded px-3 py-2 mb-3">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_journal_pages', {'code': code}) }}">
                                        <i class="fas fa-home me-1"></i>
                                        {{ 'journalPages.home' | trans }}
                                    </a>
                                </li>
                                {% if breadcrumbPath is defined and breadcrumbPath is not empty %}
                                    {% for item in breadcrumbPath %}
                                        <li class="breadcrumb-item">
                                            {% if item.type == 'page' and item.code is defined %}
                                                <a href="{{ path('app_journal_page_view', {'code': code, 'pageCode': item.code|page_slug}) }}">
                                                    {{ item.title[app.request.locale] ?? item.title[defaultLanguage] ?? item.title['en'] ?? 'Unknown' }}
                                                </a>
                                            {% else %}
                                                <span class="text-muted">
                                                        {{ item.title[app.request.locale] ?? item.title[defaultLanguage] ?? item.title['en'] ?? 'Unknown' }}
                                                    </span>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                {% endif %}
                                <li class="breadcrumb-item active" aria-current="page">
                                    {{ currentPageData.title[app.request.locale] ?? currentPageData.title[defaultLanguage] ?? currentPageData.pageCode }}
                                </li>
                            </ol>
                        </nav>

                        {% if editMode|default(false) %}
                            <!-- Edit Mode: Form open by default -->
                            {% include 'pages/_page_form.html.twig' with {
                                code: code,
                                acceptedLanguages: acceptedLanguages,
                                defaultLanguage: defaultLanguage,
                                pageData: currentPageData,
                                formAction: path('app_journal_page_edit', {'code': code, 'pageCode': currentPage}),
                                csrfTokenId: 'page-edit',
                                formOpen: true
                            } %}
                        {% else %}
                            <!-- View Mode: Page Content Display -->
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-file-alt me-2"></i>{{ 'journalPages.pageContent'|trans|default('Page Content') }}
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <!-- Title -->
                                    <div class="mb-3">
                                        <label class="form-label text-primary fw-semibold">
                                            {{ 'journalPages.form.title'|trans }}
                                            <span class="badge bg-secondary ms-2">{{ 'journalPages.notEditable'|trans }}</span>
                                        </label>
                                        <div id="page-view-title" class="form-control bg-light">
                                            {{ currentPageData.title[defaultLanguage] ?? currentPageData.pageCode }}
                                        </div>
                                    </div>

                                    <!-- Content -->
                                    <div class="mb-3">
                                        <label class="form-label text-primary fw-semibold">
                                            {{ 'journalPages.form.content'|trans }}
                                        </label>
                                        <div id="page-view-content" class="ck-content border rounded p-3 bg-white">
                                            {# Use interface locale, NO fallback to default language #}
                                            {% set localeContent = currentPageData.content[app.request.locale]|default('') %}
                                            {% if localeContent is not empty %}
                                                {{ localeContent|raw }}
                                            {% else %}
                                                <p class="text-muted fst-italic no-content-message">{{ 'journalPages.noContentAvailable'|trans }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer text-end">
                                    <a href="{{ path('app_journal_page_edit', {'code': code, 'pageCode': currentPage}) }}"
                                       class="btn btn-primary">
                                        <i class="fas fa-edit me-1"></i>
                                        {{ 'journalPages.edit' | trans }}
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    {% else %}
                        <!-- Home / Welcome Screen -->
                        <div class="card">
                            <div class="card-body">
                                <div class="text-center py-5">
                                    <i class="fas fa-home fa-3x text-primary mb-3"></i>
                                    <h3>{{ 'journalPages.welcomeTitle' | trans }}</h3>
                                    <p class="text-muted">{{ 'journalPages.selectPageFirst' | trans }}</p>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>

                <div class="journal-layout__widget">
                    <!-- Language Widget for viewing (changes interface language) -->
                    {{ include('components/language_widget.html.twig', {
                        widgetId: 'sidebar',
                        acceptedLanguages: acceptedLanguages|default(['en', 'fr']),
                        defaultLanguage: defaultLanguage
                    }) }}

                    {# TODO: Visibility display/selector - commented for future use
                    {% if currentPageData is defined and currentPageData is not null %}
                        <div class="card mt-3">
                            <div class="card-header">
                                <h6 class="mb-0">{{ 'journalPages.form.visibility'|trans|default('Visibility')
                                    }}</h6>
                                <small class="text-muted">
                                    {% if editMode|default(false) %}
                                        {{ 'journalPages.form.visibilityHelp'|trans|default('Select which roles
   can view this page') }}
                                    {% else %}
                                        {{ 'journalPages.form.visibilityInfo'|trans|default('Roles that can
  view this page') }}
                                    {% endif %}
                                </small>
                            </div>
                            <div class="card-body">
                                {% if editMode|default(false) %}
                                    {* Edit mode: checkboxes *}
                                    {% for role in visibilityRoles|default(['public']) %}
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="visibility[]"
                                                   form="page-form" value="{{ role }}" id="visibility_{{ role }}" {% if currentPageData.visibility is defined
                                                       and role in currentPageData.visibility %}checked{% endif %}>
                                            <label class="form-check-label" for="visibility_{{ role }}">
                                                {{ ('role.' ~ role)|trans|default(role|capitalize) }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    {* View mode: badges *}
                                    {% for role in currentPageData.visibility|default(['public']) %}
                                        <span class="badge bg-primary me-1">{{ ('role.' ~
                                            role)|trans|default(role|capitalize) }}</span>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                    #}
                </div>
            </div>
        </div>
    </div>
        <!-- Right empty column (matches left) -->
        <div class="col-1 d-none d-xl-block">
            <!-- Empty to balance layout -->
        </div>
    </div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('journalPages') }}
    {{ encore_entry_link_tags('navbar') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
      window.pageConfig = {
        locale: {{ app.request.locale|json_encode|raw }},
        journalCode: {{ code|json_encode|raw }},
        acceptedLanguages: {{ acceptedLanguages|json_encode|raw }},
        defaultLanguage: {{ defaultLanguage|json_encode|raw }},
        currentPage: {{ currentPage|default('')|json_encode|raw }},
        editMode: {{ editMode|default(false)|json_encode|raw }},
        contentLanguage: {{ contentLanguage|default(null)|json_encode|raw }},
        pageData: {% if currentPageData is defined and currentPageData is not null %}{
          title: {{ currentPageData.title|json_encode|raw }},
          content: {{ currentPageData.content|json_encode|raw }},
          markdownContent: {{ currentPageData.markdownContent|json_encode|raw }}
        }{% else %}null{% endif %},
        translations: {
          noContentAvailable: {{ 'journalPages.noContentAvailable'|trans|json_encode|raw }}
        }
      };
    </script>
    {{ encore_entry_script_tags('journalPagesJs') }}
{% endblock %}
