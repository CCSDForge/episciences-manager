{% extends 'base.html.twig' %}

{% block body %}

            <!-- Main Layout with columns -->
            <div class="row gx-4">
                <!-- Left column for future content -->
                <div class="col-1 d-none d-xl-block">
                    <!-- Future content here -->
                </div>

                <!-- Main column -->
                <div class="col-12 col-xl-10">
                    <!-- Mobile: Logo + Title stacked -->
                    <div class="mobile-header d-md-none mt-3 px-3 text-center">
                        <div class="journal-logo mb-3">
                            <img src="{{ asset('build/images/logo-' ~ review.code ~ logo_suffix ~ '.svg') }}"
                                 onerror="this.onerror=null; this.src='{{ asset('build/images/logo-' ~ review.code ~ '.svg') }}';"
                                 alt="{{ review.name }} Logo" class="img-fluid logo" style="max-width: 150px;">
                        </div>
                        <div class="journal-title">
                            <h1 class="h4 mb-0 text-primary fw-bold">{{ review.name }}</h1>
                        </div>
                        <!-- Mobile Menu Button -->
                        {% if pages is defined and pages.main is not empty %}
                        <div class="mt-3">
                            <button class="btn btn-outline-primary w-100" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas">
                                <i class="fas fa-bars me-2"></i>
                                {{ 'journalDetails.menu'|trans|default('Menu') }}
                            </button>
                        </div>
                        <!-- Offcanvas Sidebar (Mobile) -->
                        <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
                            <div class="offcanvas-header">
                                <h5 class="offcanvas-title" id="sidebarOffcanvasLabel">{{ 'journalDetails.menu'|trans|default('Menu') }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                            </div>
                            <div class="offcanvas-body">
                                <nav class="nav flex-column sidebar-menu">
                                    <a class="nav-link home-nav-link py-2"
                                       href="{{ path('app_journal_detail', {'code': code, '_locale': app.request.locale}) }}"
                                       data-bs-dismiss="offcanvas">
                                        <i class="fas fa-home me-2"></i>
                                        {{ 'journalDetails.home' | trans }}
                                    </a>
                                    {% for page in pages.main %}
                                        {% set isContainer = page.type is defined and page.type == 'container' %}
                                        {% set pageKey = isContainer ? (page.title.en ?? page.title) : page.pageCode %}
                                        {% set hasSubPages = pages.sub[pageKey] is defined and pages.sub[pageKey] is not empty %}
                                        {% if hasSubPages %}
                                            {% for subPage in pages.sub[pageKey] %}
                                                {% set isSubContainer = subPage.type is defined and subPage.type == 'container' %}
                                                <a class="nav-link page-nav-link py-1"
                                                   href="#"
                                                   {% if not isSubContainer and subPage.pageCode is defined %}
                                                       data-page-code="{{ subPage.pageCode|page_slug }}"
                                                       data-journal-code="{{ code }}"
                                                   {% endif %}
                                                   data-bs-dismiss="offcanvas">
                                                    {{ subPage.title[app.request.locale] ?? subPage.title['en'] ?? (subPage.pageCode ?? '') }}
                                                </a>
                                            {% endfor %}
                                        {% else %}
                                            <a class="nav-link page-nav-link py-2"
                                               href="#"
                                               {% if not isContainer and page.pageCode is defined %}
                                                   data-page-code="{{ page.pageCode|page_slug }}"
                                                   data-journal-code="{{ code }}"
                                               {% endif %}
                                               data-bs-dismiss="offcanvas">
                                                {{ page.title[app.request.locale] ?? page.title['en'] ?? (page.pageCode ?? '') }}
                                            </a>
                                        {% endif %}
                                    {% endfor %}
                                </nav>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    <!-- Main Layout -->
                    <div class="mt-4">
                        <!-- Row 1: Logo + Title (Desktop only) -->
                        <div class="d-none d-md-flex align-items-center mb-4">
                            <!-- Logo -->
                            <div class="flex-shrink-0 text-center" style="width: 20%; min-width: 200px; max-width: 300px;">
                                <img src="{{ asset('build/images/logo-' ~ review.code ~ logo_suffix ~ '.svg') }}"
                                     onerror="this.onerror=null; this.src='{{ asset('build/images/logo-' ~ review.code ~ '.svg') }}';"
                                     alt="{{ review.name }} Logo" class="img-fluid logo">
                            </div>
                            <!-- Title -->
                            <div class="flex-grow-1 ms-4">
                                <h1 class="h3 mb-0 text-primary fw-bold">{{ review.name }}</h1>
                            </div>
                        </div>

                        <!-- Row 2: Sidebar + Content + Language Widget -->
                        <div class="journal-layout">
                            <!-- Sidebar (hidden on mobile) -->
                            <div class="journal-layout__sidebar d-none d-md-block">
                                {% if pages is defined and pages.main is not empty %}
                                <nav class="nav flex-column bg-light rounded p-3 sidebar-menu" style="position: sticky; top: 20px;">
                            <a class="nav-link home-nav-link py-2"
                               href="{{ path('app_journal_detail', {'code': code, '_locale': app.request.locale}) }}"
                               data-home-text-en="Home"
                               data-home-text-fr="Accueil">
                                <i class="fas fa-home me-2"></i>
                                {{ 'journalDetails.home' | trans }}
                            </a>

                            {% for page in pages.main %}
                                {% set isContainer = page.type is defined and page.type == 'container' %}
                                {% set pageKey = isContainer ? (page.title.en ?? page.title) : page.pageCode %}
                                {% set hasSubPages = pages.sub[pageKey] is defined and pages.sub[pageKey] is not empty %}
                                {% set collapseId = 'collapse-' ~ loop.index %}

                                {% if hasSubPages %}
                                    <a class="nav-link py-2 d-flex justify-content-between align-items-center"
                                       id="nav-{% if isContainer %}container-{{ pageKey|lower|replace({' ': '-', '.': '-', '&': 'and'}) }}{% else %}page-{{ page.pageCode }}{% endif %}"
                                       data-bs-toggle="collapse"
                                       href="#{{ collapseId }}"
                                       role="button"
                                       aria-expanded="false"
                                       aria-controls="{{ collapseId }}"
                                       {% if isContainer %}
                                           data-title-en="{{ page.title.en ?? page.title }}"
                                           data-title-fr="{{ page.title.fr ?? page.title.en ?? page.title }}"
                                           data-is-container="true"
                                       {% endif %}>
                                        <span>
                                            {% if isContainer %}
                                                {{ page.title[app.request.locale] ?? page.title['en'] ?? page.title }}
                                            {% else %}
                                                {{ page.title[app.request.locale] ?? page.title['en'] ?? page.pageCode }}
                                            {% endif %}
                                        </span>
                                        <i class="fas fa-chevron-down fa-xs"></i>
                                    </a>
                                    <div class="collapse" id="{{ collapseId }}">
                                        <nav class="nav flex-column ms-3">
                                            {% for subPage in pages.sub[pageKey] %}
                                                {% set isSubContainer = subPage.type is defined and subPage.type == 'container' %}
                                                {% set subPageKey = isSubContainer ? (subPage.title.en ?? subPage.title) : subPage.pageCode %}
                                                {% set hasNestedSubPages = isSubContainer and pages.sub[subPageKey] is defined and pages.sub[subPageKey] is not empty %}
                                                {% set subCollapseId = 'collapse-' ~ loop.parent.loop.index ~ '-' ~ loop.index %}

                                                {% if hasNestedSubPages %}
                                                    <a class="nav-link py-1 d-flex justify-content-between align-items-center"
                                                       id="nav-{% if isSubContainer %}container-{{ subPageKey|lower|replace({' ': '-', '.': '-', '&': 'and'}) }}{% else %}page-{{ subPage.pageCode }}{% endif %}"
                                                       data-bs-toggle="collapse"
                                                       href="#{{ subCollapseId }}"
                                                       role="button"
                                                       aria-expanded="false"
                                                       aria-controls="{{ subCollapseId }}"
                                                       {% if isSubContainer %}
                                                           data-title-en="{{ subPage.title.en ?? subPage.title }}"
                                                           data-title-fr="{{ subPage.title.fr ?? subPage.title.en ?? subPage.title }}"
                                                           data-is-container="true"
                                                       {% endif %}>
                                                        <span>
                                                            {% if isSubContainer %}
                                                                {{ subPage.title[app.request.locale] ?? subPage.title['en'] ?? subPage.title }}
                                                            {% else %}
                                                                {{ subPage.title[app.request.locale] ?? subPage.title['en'] ?? subPage.pageCode }}
                                                            {% endif %}
                                                        </span>
                                                        <i class="fas fa-chevron-down fa-xs"></i>
                                                    </a>
                                                    <div class="collapse" id="{{ subCollapseId }}">
                                                        <nav class="nav flex-column ms-3">
                                                            {% for nestedPage in pages.sub[subPageKey] %}
                                                                <a class="nav-link page-nav-link py-1"
                                                                   id="nav-page-{{ nestedPage.pageCode }}"
                                                                   href="#"
                                                                   data-page-code="{{ nestedPage.pageCode|page_slug }}"
                                                                   data-journal-code="{{ code }}"
                                                                   data-grandparent-title-en="{{ page.title.en ?? page.title }}"
                                                                   data-grandparent-title-fr="{{ page.title.fr ?? page.title.en ?? page.title }}"
                                                                   data-parent-title-en="{{ subPage.title.en ?? subPage.title }}"
                                                                   data-parent-title-fr="{{ subPage.title.fr ?? subPage.title.en ?? subPage.title }}"
                                                                   data-current-title-en="{{ nestedPage.title.en ?? nestedPage.pageCode }}"
                                                                   data-current-title-fr="{{ nestedPage.title.fr ?? nestedPage.title.en ?? nestedPage.pageCode }}">
                                                                    {{ nestedPage.title[app.request.locale] ?? nestedPage.title['en'] ?? nestedPage.pageCode }}
                                                                </a>
                                                            {% endfor %}
                                                        </nav>
                                                    </div>
                                                {% else %}
                                                    <a class="nav-link page-nav-link py-1"
                                                       id="nav-page-{{ subPage.pageCode }}"
                                                       href="#"
                                                       data-page-code="{{ subPage.pageCode|page_slug }}"
                                                       data-journal-code="{{ code }}"
                                                       data-parent-title-en="{% if isContainer %}{{ page.title.en ?? page.title }}{% else %}{{ page.title.en ?? page.pageCode }}{% endif %}"
                                                       data-parent-title-fr="{% if isContainer %}{{ page.title.fr ?? page.title.en ?? page.title }}{% else %}{{ page.title.fr ?? page.title.en ?? page.pageCode }}{% endif %}"
                                                       data-current-title-en="{{ subPage.title.en ?? subPage.pageCode }}"
                                                       data-current-title-fr="{{ subPage.title.fr ?? subPage.title.en ?? subPage.pageCode }}">
                                                        {{ subPage.title[app.request.locale] ?? subPage.title['en'] ?? subPage.pageCode }}
                                                    </a>
                                                {% endif %}
                                            {% endfor %}
                                        </nav>
                                    </div>
                                {% else %}
                                    <a class="nav-link page-nav-link py-2"
                                       id="nav-{% if isContainer %}container-{{ pageKey|lower|replace({' ': '-', '.': '-', '&': 'and'}) }}{% else %}page-{{ page.pageCode }}{% endif %}"
                                       {% if not isContainer %}
                                           href="#"
                                           data-page-code="{{ page.pageCode|page_slug }}"
                                           data-journal-code="{{ code }}"
                                           data-current-title-en="{{ page.title.en ?? page.pageCode }}"
                                           data-current-title-fr="{{ page.title.fr ?? page.title.en ?? page.pageCode }}"
                                       {% else %}
                                           href="#"
                                           data-title-en="{{ page.title.en ?? page.title }}"
                                           data-title-fr="{{ page.title.fr ?? page.title.en ?? page.title }}"
                                           data-is-container="true"
                                       {% endif %}>
                                        {% if isContainer %}
                                            {{ page.title[app.request.locale] ?? page.title['en'] ?? page.title }}
                                        {% else %}
                                            {{ page.title[app.request.locale] ?? page.title['en'] ?? page.pageCode }}
                                        {% endif %}
                                    </a>
                                {% endif %}
                            {% endfor %}

                            <hr class="my-2">

                            <a class="nav-link py-2"
                               href="{{ path('app_resources_manager', {'code': code}) }}"
                               target="_blank"
                               rel="noopener noreferrer">
                                <i class="fas fa-folder-open me-2"></i>
                                {{ 'resources.title'|trans }}
                            </a>

                            <a class="nav-link py-2"
                               href="{{ path('app_journal_settings', {'code': code}) }}"
                               target="_blank"
                               rel="noopener noreferrer">
                                <i class="fas fa-cog me-2"></i>
                                {{ 'journalSettings.title'|trans }}
                            </a>
                            </nav>
                            {% endif %}
                        </div>

                        <!-- Content -->
                        <div class="journal-layout__content">
                        <!-- Breadcrumb Navigation & Preview Button -->
                        <div id="breadcrumb-nav" class="bg-light rounded px-3 py-2 mb-3 d-flex justify-content-between align-items-center" style="display: none !important;">
                            <!-- Breadcrumb Navigation -->
                            <nav class="breadcrumb-container">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item">
                                        <a href="#" class="breadcrumb-home"
                                           data-home-text-en="Home"
                                           data-home-text-fr="Accueil">
                                            <i class="fas fa-home me-1"></i>
                                            {{ 'journalDetails.home' | trans }}
                                        </a>
                                    </li>
                                    <li id="breadcrumb-grandparent" class="breadcrumb-item" style="display: none;">
                                        <span class="breadcrumb-grandparent-text"></span>
                                    </li>
                                    <li id="breadcrumb-parent" class="breadcrumb-item" style="display: none;">
                                        <span class="breadcrumb-parent-text"></span>
                                    </li>
                                    <li id="breadcrumb-current" class="breadcrumb-item active" style="display: none;">
                                        <span class="breadcrumb-current-text"></span>
                                    </li>
                                </ol>
                            </nav>

                            <!-- Preview Page Button -->
                            <div id="preview-page-button-container" style="display: none;">
                                <a id="preview-page-button"
                                   href="#"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-external-link-alt me-1"></i>
                                    {{ 'journalDetails.preview_page' | trans }}
                                </a>
                            </div>
                        </div>

                        <!-- Page Content Display Area -->
                        <div class="card">
                            <div class="card-body">
                                <!-- View Mode -->
                                <div id="page-content" class="ck-content" style="display: block;">
                                    <div id="page-view-fields" style="display: none;">
                                        <div class="mb-3">
                                            <label class="form-label text-primary fw-semibold">{{ 'journalDetails.page_title' | trans }}</label>
                                            <input type="text" class="form-control" id="page-title-view" readonly>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label text-primary fw-semibold">{{ 'journalDetails.content' | trans }}</label>
                                            <div id="page-body" class="form-control" style="height: auto; min-height: 200px;"></div>
                                        </div>
                                    </div>
                                    <div id="page-home-content">
                                        <div class="text-center py-5">
                                            <i class="fas fa-home fa-3x text-primary mb-3"></i>
                                            <h3>{{ 'journalDetails.welcome_backoffice' | trans }}</h3>
                                            <p class="text-muted">{{ 'journalDetails.select_page_first' | trans }}</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Inline Edit Mode -->
                                <div id="inline-edit-content" style="display: none;">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="mb-0">
                                            <i class="fas fa-edit me-2"></i>
                                            {{ 'journalDetails.edit_page_content' | trans }}
                                            <i class="fas fa-file-alt ms-2"></i>
                                        </h5>
                                        <div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="cancel-inline-edit">
                                                <i class="fas fa-times me-1"></i>
                                                {{ 'journalDetails.cancel' | trans }}
                                            </button>
                                            <button type="button" class="btn btn-sm btn-primary" id="save-inline-edit">
                                                <i class="fas fa-save me-1"></i>
                                                {{ 'journalDetails.save' | trans }}
                                            </button>
                                        </div>
                                    </div>

                                    <form id="inline-edit-form">
                                        <div class="mb-3">
                                            <label for="page-title-inline" class="form-label">
                                                {{ 'journalDetails.page_title' | trans }}
                                            </label>
                                            <input type="text" class="form-control" id="page-title-inline">
                                        </div>
                                        <div class="mb-3">
                                            <label for="page-content-inline" class="form-label">{{ 'journalDetails.content' | trans }}</label>
                                            <div id="page-content-inline" data-placeholder="{{ 'journalDetails.enter_content' | trans }}"></div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <div class="card-footer text-end">
                                <button type="button" class="btn btn-primary" id="edit-button">
                                    <i class="fas fa-edit me-1"></i>
                                    {{ 'journalDetails.edit' | trans }}
                                </button>
                            </div>
                        </div>
                        </div>

                        <!-- Language Widget (Responsive) -->
                        {% set langCodes = { en: 'En', fr: 'Fr', es: 'Es', de: 'De', it: 'It', pt: 'Pt', nl: 'Nl', ar: 'Ar', zh: 'Zh', ja: 'Ja' } %}
                        {% set langNames = { en: 'English', fr: 'Français', es: 'Español', de: 'Deutsch', it: 'Italiano', pt: 'Português', nl: 'Nederlands', ar: 'العربية', zh: '中文', ja: '日本語' } %}
                        <div class="journal-layout__widget">
                            <div class="language-widget">
                                <div class="language-widget-header bg-light d-flex justify-content-between align-items-center border" id="languageWidgetHeader">
                                    <span class="fw-semibold small">{{ 'journalDetails.languages'|trans|default('Langues') }}</span>
                                    <button class="btn btn-link btn-sm p-0 text-muted d-none d-xl-inline-block" type="button" data-bs-toggle="collapse" data-bs-target="#languageWidgetBody" aria-expanded="true">
                                        <i class="fas fa-chevron-up fa-xs"></i>
                                    </button>
                                </div>
                                <div class="collapse show" id="languageWidgetBody">
                                    <div class="language-select-section bg-white border border-top-0 px-3 py-2">
                                        <label for="sidebar-language-select" class="form-label small text-muted mb-1">{{ 'journalDetails.language'|trans|default('Langue') }}</label>
                                        <select class="form-select form-select-sm language-switch-select" id="sidebar-language-select">
                                            {% for lang in acceptedLanguages|default(['en', 'fr']) %}
                                                <option value="{{ lang }}" {{ app.request.locale == lang ? 'selected' : '' }}>{{ langNames[lang]|default(lang) }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <!-- Traductions section -->
                                    <div class="translations-section bg-white border border-top-0 rounded-bottom px-3 py-2">
                                        <label class="form-label small text-muted mb-1">{{ 'journalDetails.translations'|trans|default('Traductions') }}</label>
                                        <div id="translations-list" class="translations-list">
                                            {% for lang in acceptedLanguages|default(['en', 'fr']) %}
                                                <div class="translation-row d-flex align-items-center" data-lang="{{ lang }}">
                                                    <span class="translation-flag" title="{{ langNames[lang]|default(lang) }}">{{ langCodes[lang]|default('') }}</span>
                                                    <button class="btn btn-link btn-sm p-0 translation-action-btn" type="button" title="{{ 'journalDetails.add_translation'|trans|default('Ajouter') }}">
                                                        <i class="fas fa-plus text-muted"></i>
                                                    </button>
                                                    <input type="text" class="form-control form-control-sm translation-title-input" readonly placeholder="{{ langNames[lang]|default(lang) }}" aria-label="{{ langNames[lang]|default(lang) }}">
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </div>

                <!-- Right empty column (matches left) -->
                <div class="col-1 d-none d-xl-block">
                    <!-- Empty to balance layout -->
                </div>
            </div>


{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('journalDetails') }}
    {{ encore_entry_link_tags('navbar') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.journalDetailsData = {
            locale: {{ app.request.locale|json_encode|raw }},
            acceptedLanguages: {{ acceptedLanguages|default(['en', 'fr'])|json_encode|raw }},
            csrfToken: {{ csrf_token('page-edit')|json_encode|raw }},
            translations: {
                noContentAvailable: {{ 'journalDetails.noContentAvailable'|trans|json_encode|raw }},
                translations: {{ 'journalDetails.translations'|trans|default('Traductions')|json_encode|raw }},
                addTranslation: {{ 'journalDetails.add_translation'|trans|default('Ajouter une traduction')|json_encode|raw }},
                editTranslation: {{ 'journalDetails.edit_translation'|trans|default('Modifier la traduction')|json_encode|raw }}
            }
        };
    </script>
    {{ encore_entry_script_tags('journalDetailsJs') }}
{% endblock %}