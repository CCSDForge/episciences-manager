{% extends 'base.html.twig' %}                                                                
                                                                                                
  {% block title %}{{ 'journalConfiguration.selectJournal'|trans }}{% endblock %}               
                                                                                                
  {% block body %}
      <div class="container py-4">
          <div class="row justify-content-center">
              <div class="col-lg-8">
                  <h1 class="mb-4">
                      <i class="fas fa-cog me-2"></i>
                      {{ 'journalConfiguration.title'|trans }}
                  </h1>

                  <div class="card">
                      <div class="card-header">
                          <i class="fas fa-book me-2"></i>
                          {{ 'journalConfiguration.selectJournal'|trans }}
                      </div>
                      <div class="card-body">
                          <div class="mb-3">
                              <input type="text" class="form-control" id="journal-search"
                                     placeholder="{{ 'journalConfiguration.searchPlaceholder'|trans
                                     }}">
                          </div>

                          <div class="list-group" id="journal-list">
                              {% for journal in journals %}
                                  <a href="{{ path('app_journal_configuration', {'code':
                                      journal.code}) }}"
                                     class="list-group-item list-group-item-action d-flex
  justify-content-between align-items-center journal-item"
                                     data-name="{{ journal.name|lower }}"
                                     data-code="{{ journal.code|lower }}">
                                      <div>
                                          <strong>{{ journal.name }}</strong>
                                          <span class="badge bg-secondary ms-2">{{ journal.code
                                              }}</span>
                                      </div>
                                      <i class="fas fa-chevron-right text-muted"></i>
                                  </a>
                              {% else %}
                                  <div class="text-muted text-center py-3">
                                      {{ 'journalConfiguration.noJournals'|trans }}
                                  </div>
                              {% endfor %}
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </div>
  {% endblock %}                                                                                
                                                                                                
  {% block javascripts %}
      {{ parent() }}
      <script>
          document.addEventListener('DOMContentLoaded', function() {
              const searchInput = document.getElementById('journal-search');
              const journalItems = document.querySelectorAll('.journal-item');

              searchInput.addEventListener('input', function() {
                  const searchTerm = this.value.toLowerCase().trim();

                  journalItems.forEach(function(item) {
                      const name = item.dataset.name;
                      const code = item.dataset.code;

                      if (name.includes(searchTerm) || code.includes(searchTerm)) {
                          item.style.display = '';
                      } else {
                          item.style.display = 'none';
                      }
                  });
              });
          });
      </script>
  {% endblock %}                  