{% extends 'base.html.twig' %}

{% block title %}{{ 'selectJournal.title'|trans }}{% endblock %}

{% block body %}
    <div class="journal-config-page">
        <div class="container">
            {% if app.user and app.user.userIdentifier != '__NO_USER__' %}
                {% include 'partials/_navbar.html.twig' %}
            {% endif %}
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="journal-config-card">
                        <div class="card-header">
                            <i class="fas fa-book"></i>
                            {{ 'selectJournal.title'|trans }}
                        </div>
                        <div class="card-body">
                            <div class="search-container">
                                <form method="GET" action="{{ path('app_journal_configuration_select') }}" class="search-form">
                                    <div class="search-wrapper">
                                        <input type="text"
                                               name="search"
                                               class="form-control form-control-lg"
                                               placeholder="{{ 'selectJournal.searchPlaceholder'|trans }}"
                                               value="{{ search|default('') }}"
                                               autocomplete="off">
                                        {% if search|default('') is not empty %}
                                            <a href="{{ path('app_journal_configuration_select') }}" class="clear-btn" title="{{ 'selectJournal.clearSearch'|trans }}">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        {% endif %}
                                        <button class="search-btn" type="submit">
                                            <i class="fas fa-search"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <div class="journal-list">
                                {% for journal in journals %}
                                    <a href="{{ path('app_journal_configuration', {'code': journal.code}) }}"
                                       class="journal-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="journal-name">{{ journal.name }}</span>
                                            <span class="badge bg-secondary ms-2">{{ journal.code }}</span>
                                        </div>
                                        <i class="fas fa-chevron-right text-muted"></i>
                                    </a>
                                {% else %}
                                    <div class="no-results">
                                        <i class="fas fa-search"></i>
                                        <p>
                                            {% if search|default('') is not empty %}
                                                {{ 'selectJournal.noResults'|trans }}
                                            {% else %}
                                                {{ 'selectJournal.noJournals'|trans }}
                                            {% endif %}
                                        </p>
                                    </div>
                                {% endfor %}
                            </div>

                            {% if pagination %}
                                <div class="pagination-wrapper">
                                    <div class="d-flex justify-content-center">
                                        {{ knp_pagination_render(pagination) }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('selectJournal') }}
    {{ encore_entry_link_tags('navbar') }}
{% endblock %}